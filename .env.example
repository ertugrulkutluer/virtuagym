# Postgres
POSTGRES_USER=gymflow
POSTGRES_PASSWORD=gymflow_dev
POSTGRES_DB=gymflow
POSTGRES_PORT=5433

# Redis (cache + rate limit)
REDIS_PORT=6380
REDIS_URL=redis://localhost:6380

# API
API_PORT=4000
DATABASE_URL=postgresql://gymflow:gymflow_dev@localhost:5433/gymflow?schema=public
JWT_SECRET=change-me-in-prod-please
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-in-prod
JWT_REFRESH_EXPIRES_IN=7d

# Web
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# AI advisor (xAI Grok)
# Get a key at https://console.x.ai
GROK_API_KEY=replace-with-your-key
GROK_API_URL=https://api.x.ai/v1
GROK_MODEL=grok-4-fast-non-reasoning
AI_ENABLED_DEFAULT=true
AI_OVERBOOK_FACTOR=0.9
