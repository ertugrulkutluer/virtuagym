{
  "name": "gymflow",
  "version": "0.1.0",
  "private": true,
  "description": "Mini gym class booking SaaS with no-show prediction",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "db:up": "docker compose --env-file .env -f docker/docker-compose.yml up -d",
    "db:down": "docker compose --env-file .env -f docker/docker-compose.yml down",
    "db:logs": "docker compose --env-file .env -f docker/docker-compose.yml logs -f postgres"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=8"
  },
  "packageManager": "pnpm@8.14.3"
}
